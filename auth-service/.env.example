# ======= auth-service environment =======

# --- Database (SQLite file path). Default: ./prisma/dev.db ---
DATABASE_URL="file:./dev.db"

# --- JWT secrets. Generate via: openssl rand -base64 32 ---
JWT_ACCESS_SECRET=replace-me-with-32-bytes-of-base64
JWT_REFRESH_SECRET=replace-me-with-different-32-bytes
JWT_ACCESS_TTL=900            # 15 min
JWT_REFRESH_TTL=2592000       # 30 days

# --- CSRF: shared secret used to derive per-request tokens ---
CSRF_SECRET=replace-me-csrf-secret

# --- Cookies ---
COOKIE_SECURE=false           # true in production (HTTPS only)
COOKIE_DOMAIN=                # e.g. ".mauriciomilano.com" or empty for localhost
COOKIE_SAMESITE=lax

# --- Server ---
PORT=4000
NODE_ENV=development

# --- STT upstream (FastAPI service created earlier) ---
STT_ENDPOINT=http://localhost:8000
STT_API_KEY=replace-me-matching-fastapi-side

# --- CORS: comma-separated origins (empty = same-origin only) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limit (persisted in DB; safe across restarts) ---
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100

# --- Reset password: token TTL + how to "send" the email ---
RESET_TOKEN_TTL_MIN=30
RESET_LINK_BASE=http://localhost:5173/reset

# --- Logging ---
LOG_LEVEL=info
