# =============================================================================
# STT Endpoint — environment variables
# Copy to .env and fill in. All vars are prefixed STT_.
# Restart the service after any change.
# =============================================================================

# --- Auth ---
# REQUIRED. Shared secret sent as `X-API-Key` header by clients.
STT_API_KEY=change...me

# --- Whisper model ---
# Model size: tiny | base | small | medium | large-v2 | large-v3
# tiny    = ~75 MB, fastest, lowest accuracy (real-time)
# base    = ~142 MB, good balance for short clips (recommended for v1)
# small   = ~466 MB, much better, ~3x slower than base
# medium  = ~1.5 GB, production-grade
# large-v3 = ~3 GB, best accuracy
STT_MODEL_SIZE=base

# --- Compute ---
# Device for inference: cuda | cpu. 'cuda' requires nvidia-cublas-cu12 + nvidia-cudnn-cu12 in image.
STT_DEVICE=cuda

# Compute type: float16 (GPU), int8 (CPU), float32 (slow but precise).
# On CPU, the app automatically falls back to int8 if float16 is requested.
STT_COMPUTE_TYPE=float16

# --- Transcription behavior ---
# Force language code (ISO-639-1). Empty string "" means auto-detect.
# Use 'pt' for Brazilian Portuguese conversations.
STT_LANGUAGE=pt

# Beam size for decoding. 5 is default, higher = slower + more accurate.
STT_BEAM_SIZE=5

# --- Concurrency / limits ---
# How many transcriptions can run simultaneously. 1 recommended (Whisper is RAM-heavy).
STT_MAX_CONCURRENT=1

# Max upload size in MB. Whisper-large fills RAM fast; cap uploads.
STT_MAX_FILE_SIZE_MB=25

# Hard timeout per transcription. Enforced via FastAPI + executor.
STT_TIMEOUT_SECONDS=120

# --- Storage / logging ---
STT_MODELS_DIR=./models
STT_LOG_LEVEL=INFO
