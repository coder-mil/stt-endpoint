# =============================================================================
# STT Endpoint — environment variables (used by docker-compose)
# Copy this file to `.env` and fill in. NEVER commit the resulting .env.
# Generate strong secrets with: openssl rand -base64 32
# =============================================================================

# --- STT (FastAPI, faster-whisper) ---
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_MODEL_SIZE=base
STT_LANGUAGE=pt
STT_MAX_CONCURRENT=1
STT_MAX_FILE_SIZE_MB=25
STT_TIMEOUT_SECONDS=120

# --- Auth-service (Express + Prisma + SQLite) ---
# X-Api-Key value the auth-service sends to the STT upstream.
# Match the value in app/.env / STT_API_KEY of the Python service.
STT_API_KEY=replace-with-32-bytes-of-random
JWT_ACCESS_SECRET=replace-me-with-a-strong-secret
JWT_REFRESH_SECRET=replace-me-with-a-strong-secret
CSRF_SECRET=replace-me-with-a-strong-secret

# Set to "true" when you put HTTPS terminator (Traefik, Caddy, Cloudflare) in front.
COOKIE_SECURE=false

# Origin of the frontend (browser-facing). Comma-separated allowed.
CORS_ORIGINS=http://localhost:8080

# Optional — production override
NODE_ENV=production

# --- Host port for the frontend (default 8080). ---
FRONTEND_PORT=8080
