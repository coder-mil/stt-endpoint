# Build / venv artifacts
.git
.gitignore
.venv
venv
env
__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
# Build output dirs we create deliberately are copied explicitly in the
# Dockerfile; this generic `dist` rule would also strip frontend/dist.
build

# Editor / IDE
.vscode
.idea
*.swp
.DS_Store

# Runtime models / secrets (STT baker output goes to /app/models inside
# the image, not the host side, so a stray `./models` dir on host is dev only).
models
*.bin
*.pt
.env
.env.*
!.env.example

# Python source layout (build context copies app/, frontend/, etc explicitly).
tests

# Test artifacts + dev data
auth-service/test
auth-service/prisma/dev.db
auth-service/prisma/dev.db-journal

